# Example environment variables for Django application
# ===== DJANGO CORE SETTINGS =====
SECRET_KEY=generate-a-secure-random-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== DATABASE CONFIGURATION =====
# SQLite for local dev: DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL for production: DATABASE_URL=postgres://user:pass@host:5432/db_name
DATABASE_URL=

# ===== REDIS CONFIGURATION =====
REDIS_URL=redis://localhost:6379/0

# ===== EMAIL CONFIGURATION =====
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@actserv.local
ADMIN_NOTIFICATION_EMAILS=admin@yourapp.com

# ===== CORS SETTINGS =====
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===== JWT SETTINGS =====
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# ===== FILE UPLOAD SETTINGS =====
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_CONTENT_TYPES=application/pdf,image/jpeg,image/png,image/jpg,text/csv,application/vnd.ms-excel

# ===== LOGGING =====
DJANGO_LOG_LEVEL=INFO